---
// src/components/EventCard.astro
interface Props {
  title: string;
  organizer: string;
  date: string;
  eventUrl: string;
  imagePath?: string; // 1. Añadimos la propiedad para la imagen
}

const { title, organizer, date, eventUrl, imagePath } = Astro.props;
---

<div class="event-card">
  <div class="event-icon">
    {imagePath ? (
      <img src={imagePath} alt={`Logo de ${organizer}`} class="event-logo" loading="lazy" />
    ) : (
      <span>📍</span>
    )}
  </div>
  
  <div class="event-info">
    <span class="event-type tech-font">EVENTO</span>
    <h3>{title}</h3>
    <p class="organizer">{organizer}</p>
    <div class="footer-info">
      <p class="date tech-font">{date}</p>
      <a href={eventUrl} target="_blank" class="event-link tech-font">Ver evento -></a>
    </div>
  </div>
</div>

<style>
  .event-card {
    background-color: var(--bg-surface);
    border: 1px solid var(--border-color);
    padding: 1.5rem;
    border-radius: 12px;
    display: flex;
    gap: 1.25rem;
    transition: all 0.3s ease;
  }

  .event-card:hover {
    border-color: var(--accent);
    background-color: rgba(56, 189, 248, 0.05);
    transform: translateX(5px);
  }

  .event-icon {
    font-size: 1.5rem;
    background: var(--bg-main);
    width: 50px;
    height: 50px;
    min-width: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%; /* Esto hace que el contenedor sea redondo */
    border: 1px solid var(--border-color);
    overflow: hidden; /* Esto asegura que la imagen no se salga del círculo */
  }

  /* 3. Estilos específicos para el logo dentro del círculo */
  .event-logo {
    width: 100%;
    height: 100%;
    object-fit: cover; /* Cambia a 'contain' si los logos se cortan mucho */
  }

  .event-type {
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 1px;
  }

  .event-info {
    width: 100%;
  }

  .event-info h3 {
    font-size: 1rem;
    margin: 0.2rem 0;
    line-height: 1.2;
  }

  .organizer {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .footer-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.5rem;
  }

  .date {
    font-size: 0.75rem;
    opacity: 0.7;
  }

  .event-link {
    font-size: 0.75rem;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .event-link:hover {
    color: var(--accent);
    text-decoration: underline;
  }
</style>